@model EtkinlikPortali.Models.Event

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">✏️ Etkinliği Düzenle</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Etkinlik Adı</label>
                    <input asp-for="Title" class="form-control" />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tarih</label>
                        <input asp-for="Date" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Konum</label>
                        <input asp-for="Location" class="form-control" />
                    </div>
                    <div class="mb-3">
    <label class="form-label fw-bold">Kategori</label>
    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
        <option value="">-- Kategori Seçiniz --</option>
    </select>
    <div class="mb-3">
    <label class="form-label fw-bold">Görsel URL Adresi</label>
    <input asp-for="ImageUrl" class="form-control" placeholder="https://site.com/resim.jpg" />
    <small class="text-muted">İnternetten bulduğunuz bir resmin bağlantısını buraya yapıştırabilirsiniz.</small>
</div>
    <div class="mb-3">
    <label class="form-label fw-bold">Etkinlik Açıklaması (Hakkında)</label>
    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Etkinlik hakkında detaylı bilgi giriniz..."></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>
</div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary px-4">Güncelle</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>